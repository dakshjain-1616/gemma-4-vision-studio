# Gemma 4 Vision Studio — API Configuration
# Copy this file to .env and fill in your key.
#
#   cp .env.example .env
#
# If neither key is set, the app starts in mock mode
# (demo responses only — no real AI inference).

# ── Inference Backend Selection ───────────────────────────────────────────────
# Set INFERENCE_BACKEND to explicitly choose a provider:
#   'ollama'     → Local Ollama server
#   'llamacpp'   → Local llama.cpp server
#   'openrouter' → OpenRouter API (cloud)
#   'google'     → Google AI Studio API (cloud)
#   'mock'       → Demo mode (no AI, fake responses)
# If not set, provider is auto-selected from API keys.
# INFERENCE_BACKEND=

# ── Local Inference: Ollama ───────────────────────────────────────────────────
# Install Ollama: https://ollama.com
# Pull Gemma 4: ollama pull gemma4  (or gemma4:e2b / gemma4:27b)
# Start the server: ollama serve
# INFERENCE_BACKEND=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma4

# ── Local Inference: llama.cpp ────────────────────────────────────────────────
# Build llama.cpp with server: https://github.com/ggerganov/llama.cpp
# Download Gemma 4 GGUF: https://huggingface.co/unsloth/gemma-4-27B-it-GGUF
# Run: ./llama-server -m gemma-4-27b-it-Q4_K_M.gguf --port 8080
# INFERENCE_BACKEND=llamacpp
# LLAMACPP_BASE_URL=http://localhost:8080
# LLAMACPP_MODEL=gemma-4-27b-it-Q4_K_M.gguf

# ── Option 1: OpenRouter (recommended) ───────────────────────────────────────
# OpenRouter gives you access to Gemma, GPT-4, Claude, and 100+ other models
# through one OpenAI-compatible API.
# Sign up and get a key at: https://openrouter.ai
OPENROUTER_API_KEY=

# Which model to use via OpenRouter (optional — default shown below)
# google/gemma-4-31b-it        — default, 31B, full vision (image+video+text), 262K context
# google/gemma-4-31b-it:free   — same model, free tier (rate-limited)
# google/gemma-4-26b-a4b-it    — 26B MoE variant, also vision-capable
# OPENROUTER_MODEL=google/gemma-4-31b-it

# ── Option 2: Google AI Studio ───────────────────────────────────────────────
# Direct access to Google's generative language API.
# Get a free key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemma-4-31b-it

# ── Notes ─────────────────────────────────────────────────────────────────────
# • INFERENCE_BACKEND takes priority over API keys when explicitly set.
# • For local inference, set INFERENCE_BACKEND to 'ollama' or 'llamacpp'.
# • Local backends don't require API keys and use base64-encoded images.
