# Gemma 4 Vision Studio — API Configuration
# Copy this file to .env and fill in your key.
#
#   cp .env.example .env
#
# If neither key is set, the app starts in mock mode
# (demo responses only — no real AI inference).

# ── Option 1: OpenRouter (recommended) ───────────────────────────────────────
# OpenRouter gives you access to Gemma, GPT-4, Claude, and 100+ other models
# through one OpenAI-compatible API.
# Sign up and get a key at: https://openrouter.ai
OPENROUTER_API_KEY=

# Which model to use via OpenRouter (optional — default shown below)
# google/gemma-4-31b-it        — default, 31B, full vision (image+video+text), 262K context
# google/gemma-4-31b-it:free   — same model, free tier (rate-limited)
# google/gemma-4-26b-a4b-it    — 26B MoE variant, also vision-capable
# OPENROUTER_MODEL=google/gemma-4-31b-it

# ── Option 2: Google AI Studio ───────────────────────────────────────────────
# Direct access to Google's generative language API.
# Get a free key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemma-4-31b-it

# ── Notes ─────────────────────────────────────────────────────────────────────
# • OPENROUTER_API_KEY takes priority over GEMINI_API_KEY if both are set.
# • For local inference (no API key), install Ollama (https://ollama.com) and run:
#     ollama run gemma4
#   Then set:
#   OPENROUTER_API_KEY=ollama
#   OPENROUTER_BASE_URL=http://localhost:11434/v1
#   OPENROUTER_MODEL=gemma4
